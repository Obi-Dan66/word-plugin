{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Task Pane (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "https://localhost:3000/taskpane.html",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///*": "*"
      }
    },
    {
      "name": "Attach to Task Pane (Chrome)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///*": "*"
      }
    }
  ]
}
